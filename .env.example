# Copy to .env.local and fill in. Never commit real secrets.

# PostgreSQL connection used by the app (Drizzle). For the local Docker DB:
DATABASE_URL=postgres://libraryloop:libraryloop@localhost:5432/libraryloop

# Secret used to sign/verify session cookies. Generate a long random value,
# e.g. `openssl rand -base64 32`.
AUTH_SECRET=replace-with-a-long-random-secret

# New York Times Best Seller API key (used by the nyt-recommendations feature).
NYT_API_KEY=

# Local Docker Postgres credentials (read by docker-compose.yml). Local only.
POSTGRES_USER=libraryloop
POSTGRES_PASSWORD=libraryloop
POSTGRES_DB=libraryloop
POSTGRES_PORT=5432
