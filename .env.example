# Copy to .env.local and fill in. Never commit real secrets.

# PostgreSQL connection used by the app (Drizzle). For the local Docker DB:
DATABASE_URL=postgres://libraryloop:libraryloop@localhost:5432/libraryloop

# Secret used to sign/verify session cookies. Generate a long random value,
# e.g. `openssl rand -base64 32`.
AUTH_SECRET=replace-with-a-long-random-secret

# --- Trending Now providers (server-side only; never exposed to the browser) ---
# New York Times Best Seller API key — the books provider for Trending Now.
NYT_API_KEY=

# Spotify app credentials — the music provider for Trending Now. Uses the
# client-credentials OAuth flow (no user login); create an app at
# https://developer.spotify.com/dashboard to obtain these.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# TMDB (The Movie Database) API key — the TV & movie provider for Trending Now.
# Free; create a key at https://www.themoviedb.org/settings/api. When unset, the
# TV/movie trending sources report as "unconfigured" (podcasts/books/music still
# work). Podcasts use Apple's keyless public charts and need no key.
TMDB_API_KEY=

# Local Docker Postgres credentials (read by docker-compose.yml). Local only.
# If a system Postgres already uses 5432, set POSTGRES_PORT=5433 here AND change
# the DATABASE_URL port above to match.
POSTGRES_USER=libraryloop
POSTGRES_PASSWORD=libraryloop
POSTGRES_DB=libraryloop
POSTGRES_PORT=5432
